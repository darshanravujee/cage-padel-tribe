# EDIT ME: Add your environment variables here
# Copy this file to .env.local and fill in actual values

# Analytics
# NEXT_PUBLIC_GA_ID=UA_XXXXXXXXX_X

# Playtomic
# NEXT_PUBLIC_PLAYTOMIC_VENUE_ID=your_venue_id

# Email Service (Formspree, SendGrid, etc.)
# NEXT_PUBLIC_FORMSPREE_ID=your_form_id
# SENDGRID_API_KEY=your_api_key

# Stripe
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...

# Shop / E-Commerce
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_token

# API URLs
# NEXT_PUBLIC_API_URL=https://api.cagepadeltrib.com
